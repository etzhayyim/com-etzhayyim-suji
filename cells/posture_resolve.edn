{:cell/id "posture_resolve"
 :cell/glyph "筋"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "gad"
 :cell/doc "Resolve a laptop workstation setup into sagittal joint angles (methods/posture.py): screen-below-eye → head flexion (tech-neck driver), keyboard-above-elbow → shoulder reach/shrug, backrest → trunk lean. A documented monotonic kinematic model, NOT a biometric measurement (kizashi owns sensing). Emits a postureScenario Datom (as-of). R0 scaffold (.solve() raises)."
 :cell/entry "cells/posture_resolve/cell.py"
 :cell/handler "PostureResolveCell"
 :cell/state-graph {:nodes [:read-workstation :map-angles :emit] :entry :read-workstation
                    :edges [[:read-workstation :map-angles] [:map-angles :emit] [:emit :end]]}
 :cell/gates ["G3" "G9"]
 :cell/kotoba {:reads [:posture/workstation] :writes [:posture/id :posture/head-flex-deg :posture/as-of]}}
