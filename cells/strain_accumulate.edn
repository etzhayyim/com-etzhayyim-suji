 :cell/state-graph {:nodes [:read-tensions :rohmert-dose :band :emit] :entry :read-tensions
                    :edges [[:read-tensions :rohmert-dose] [:rohmert-dose :band] [:band :emit] [:emit :end]]}
 :cell/gates ["G1" "G3" "G9" "G10"]
