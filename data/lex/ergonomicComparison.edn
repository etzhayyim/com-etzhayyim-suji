[{:db/id -1, :suji.lex.ergonomicComparison/lexicon 1, :suji.lex.ergonomicComparison/id "com.etzhayyim.suji.ergonomicComparison", :suji.lex.ergonomicComparison/defs "{:main {:type \"record\", :key \"comparisonId\", :record {:type \"object\", :comment \"G3 self-referenced Wellbecoming: a comparison of the SAME body across workstation setups (the choice 'raise the screen / support the arms'). NOT medical advice and NOT a person ranking; the mechanism is reported, the clinician owns interpretation.\", :required [\"comparisonId\" \"baselinePostureId\" \"improvedPostureId\" \"cervicalLoadReductionPct\"], :additionalProperties false, :properties {:comparisonId {:type \"string\"}, :baselinePostureId {:type \"string\"}, :improvedPostureId {:type \"string\"}, :cervicalLoadReductionPct {:type \"number\", :description \"reduction in cervical compressive load from baseline → improved\"}, :worstMuscleBaseline {:type \"string\"}, :worstMuscleImproved {:type \"string\"}, :mechanismNote {:type \"string\", :description \"the physical mechanism (e.g. 'lower head flexion reduces the dominant cervical-load term'); never a prescription\"}}}}}"}]
