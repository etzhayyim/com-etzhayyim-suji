[{:db/id -1, :suji.lex.jointLoad/lexicon 1, :suji.lex.jointLoad/id "com.etzhayyim.suji.jointLoad", :suji.lex.jointLoad/defs "{:main {:type \"record\", :key \"loadId\", :record {:type \"object\", :required [\"loadId\" \"postureId\" \"joint\" \"momentNm\"], :additionalProperties false, :properties {:loadId {:type \"string\"}, :postureId {:type \"string\"}, :joint {:type \"string\", :enum [\"cervicothoracic\" \"shoulder\" \"lumbosacral\"], :description \"G1 — a joint, not a body part with a diagnosis\"}, :momentNm {:type \"number\", :description \"static gravitational moment the joint resists (RNEA gravity term)\"}, :compressiveKgf {:type \"number\", :description \"cervical only — compressive spinal load (Hansraj unit); a FORCE, never a diagnosis (G1, 医師法 §17)\"}, :multVsHead {:type \"number\", :description \"cervical compressive load as a multiple of head weight (the tech-neck figure)\"}}}}}"}]
