[{:db/id -1, :suji.lex.strainReport/lexicon 1, :suji.lex.strainReport/id "com.etzhayyim.suji.strainReport", :suji.lex.strainReport/defs "{:main {:type \"record\", :key \"strainId\", :record {:type \"object\", :comment \"G1 NON-DIAGNOSTIC (医師法 §17): this record carries a mechanical load-time DOSE only. There is deliberately NO diagnosis / disease / prescription / treatment / icd / bodyPart-with-condition property, and additionalProperties=false makes any such field structurally unrepresentable (the nusa :thc-class / tazuna :weaponizable / kamado :fossil-virgin-crude pattern). A high stiffness index means 'this muscle has worked hard for a long time' — the mechanism of ordinary postural discomfort — never a clinical finding. A licensed clinician (mitate/iyashi) owns any diagnosis.\", :required [\"strainId\" \"postureId\" \"group\" \"sessionMinutes\" \"stiffnessIndex\" \"band\"], :additionalProperties false, :properties {:strainId {:type \"string\"}, :postureId {:type \"string\"}, :group {:type \"string\", :enum [\"cervical-extensors\" \"upper-trapezius\" \"levator-scapulae\" \"anterior-deltoid\" \"erector-spinae\"]}, :sessionMinutes {:type \"number\", :description \"duration the static posture was held\"}, :enduranceMinutes {:type \"number\", :description \"Rohmert acute endurance limit at this %MVC; -1 encodes effectively-unlimited (low-load)\"}, :stiffnessIndex {:type \"number\", :minimum 0, :maximum 1, :description \"強張り — 1 - exp(-dose); SELF-REFERENCED (G3), compared only against the same member's other postures, never a population rank (非終末論, no final state)\"}, :band {:type \"string\", :enum [\"low\" \"moderate\" \"high\" \"very-high\"], :description \"coarse display band; non-diagnostic\"}, :asOf {:type \"integer\"}}}}}"}]
