;; suji (筋) :representative seed (G7) — R0, no member scan, no live kizashi feed (G8).
;; A 50th-percentile adult across the three reference laptop workstations, mirroring the
;; methods/analyze.py output. NON-DIAGNOSTIC (G1): mechanical loads only. SELF-REFERENCED
;; (G3): one body across postures — a Wellbecoming choice, never a ranking of people.
[;; ── body model (population avg; NOT a member, so no encrypted-cid; representative true) ──
 {:body/id "ref-adult-70-170" :body/total-mass-kg 70.0 :body/stature-m 1.70 :body/representative true}

 ;; ── posture A: laptop-on-lap (worst — deep neck flexion, arms unsupported) ──────
 {:posture/id "p-lap" :posture/body "ref-adult-70-170" :posture/workstation "laptop-on-lap"
  :posture/head-flex-deg 44.0 :posture/trunk-flex-deg 20.0 :posture/shoulder-flex-deg 15.0
  :posture/arms-supported false :posture/as-of 0}
 {:load/id "l-lap-cerv" :load/posture "p-lap" :load/joint :cervicothoracic
  :load/moment-nm 3.85 :load/compressive-kgf 23.6 :load/mult-vs-head 4.2}
 {:load/id "l-lap-lumb" :load/posture "p-lap" :load/joint :lumbosacral :load/moment-nm 11.6}
 {:muscle/id "m-lap-cerv" :muscle/posture "p-lap" :muscle/group :cervical-extensors
  :muscle/force-n 192.0 :muscle/mvc-pct 27.0}
 {:muscle/id "m-lap-es" :muscle/posture "p-lap" :muscle/group :erector-spinae
  :muscle/force-n 530.0 :muscle/mvc-pct 26.0}
 {:strain/id "s-lap-cerv" :strain/posture "p-lap" :strain/group :cervical-extensors
  :strain/session-min 120.0 :strain/endurance-min 4.0 :strain/stiffness 1.00 :strain/band :very-high :strain/as-of 0}
 {:strain/id "s-lap-es" :strain/posture "p-lap" :strain/group :erector-spinae
  :strain/session-min 120.0 :strain/endurance-min 4.0 :strain/stiffness 1.00 :strain/band :very-high :strain/as-of 0}

 ;; ── posture B: laptop-on-desk (medium — supported, but screen still low) ────────
 {:posture/id "p-desk" :posture/body "ref-adult-70-170" :posture/workstation "laptop-on-desk"
  :posture/head-flex-deg 27.0 :posture/trunk-flex-deg 5.0 :posture/shoulder-flex-deg 20.0
  :posture/arms-supported true :posture/as-of 1}
 {:load/id "l-desk-cerv" :load/posture "p-desk" :load/joint :cervicothoracic
  :load/moment-nm 2.52 :load/compressive-kgf 17.9 :load/mult-vs-head 3.2}
 {:muscle/id "m-desk-cerv" :muscle/posture "p-desk" :muscle/group :cervical-extensors
  :muscle/force-n 126.0 :muscle/mvc-pct 18.0}
 {:strain/id "s-desk-cerv" :strain/posture "p-desk" :strain/group :cervical-extensors
  :strain/session-min 120.0 :strain/endurance-min 11.0 :strain/stiffness 1.00 :strain/band :very-high :strain/as-of 1}

 ;; ── posture C: external monitor at eye level + external keyboard (best) ─────────
 {:posture/id "p-mon" :posture/body "ref-adult-70-170" :posture/workstation "external-monitor+keyboard"
  :posture/head-flex-deg 5.0 :posture/trunk-flex-deg 5.0 :posture/shoulder-flex-deg 15.0
  :posture/arms-supported true :posture/as-of 2}
 {:load/id "l-mon-cerv" :load/posture "p-mon" :load/joint :cervicothoracic
