{:lexicon 1
 :id "com.etzhayyim.suji.postureScenario"
 :defs
 {:main
  {:type "record"
   :key "postureId"
   :record
   {:type "object"
    :required ["postureId" "bodyId" "headFlexDeg" "trunkFlexDeg" "shoulderFlexDeg" "armsSupported"]
    :additionalProperties false
    :properties
    {:postureId {:type "string"}
     :bodyId {:type "string"}
     :workstation {:type "string" :description ":representative scenario name (laptop-on-lap / laptop-on-desk / external-monitor+keyboard)"}
     :headFlexDeg {:type "number" :description "forward head flexion (tech-neck driver); 0 = ear over shoulder"}
     :trunkFlexDeg {:type "number"}
     :shoulderFlexDeg {:type "number"}
     :armsSupported {:type "boolean"}
     :asOf {:type "integer" :description "Wellbecoming trajectory stamp (非終末論 — no final state)"}}}}}}
